function cd() {
    builtin cd $1 && ls
}

function ggg() {
    gaa
    gss
    tag=$(git rev-parse --abbrev-ref HEAD | cut -d'-' -f1)
    issue=$(git rev-parse --abbrev-ref HEAD | cut -d'-' -f1-2)
    if [[ $# == 1 ]]; then
        gcmsg "$issue: $1"
    else
        vared -p "> " -c msg
        echo "Commit message: $msg"
        # if [[ $tag == "MRC" ]]; then
        #     gcmsg "$issue: $msg"
        # else
        gcmsg "$msg"
        # fi
    fi
    msg=""
}

# Session
