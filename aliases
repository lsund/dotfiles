#!/bin/zsh

# Aliases
alias n='nnn'
alias df='pydf'
alias chd='. /home/lsund/Documents/scripts/chd'
alias qcd='. /home/lsund/Documents/scripts/quick-cd'
alias find='fd -H'
alias vim='nvim'
alias mplayer='/home/lsund/Documents/scripts/mplayer-log-time'
alias ls='ls --color=auto'
alias la='ls -a --color=auto'
alias ll='ls -l --color=auto'
alias lla='ls -la --color=auto'
alias grep='grep --color'
alias beep='mplayer /home/lsund/Media/audio/sounds/beep.mp3 1>& /dev/null'
alias siren='mplayer /home/lsund/Media/audio/sounds/siren.wav 1>& /dev/null'
alias rm='$HOME/Documents/scripts/rm'
alias untargz='tar -xvzf'
alias un7z='7z e'

alias keys='setxkbmap dvorak -option compose:caps'

alias shutdown='sudo shutdown now -P'
alias restart='sudo shutdown now -r'

alias tmux='tmux -2'
alias zath='zathura'

alias network-scan='sudo iwlist wlp58s0 scan | grep ESSID'
alias my-ip="curl -s checkip.dyndns.org | \
    sed -e 's/.*Current IP Address: //' -e 's/<.*$//'"

alias combine-pdf='gs -dBATCH -dNOPAUSE -q -sDEVICE=pdfwrite \
    -sOutputFile=$3 $1 $2'

alias tex-template='cp ~/Documents/templates/tex/report.tex .'

function cdl {
    cd $1
    ls
}

alias eclipse='SWT_GTK3=0 eclipse > /dev/null'

alias redshift='redshift -l 51.2:6.7 -t 5500:3400 -g 0.8 -m randr &'
