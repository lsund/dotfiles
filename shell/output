#!/bin/zsh

if [[ $1 == "DP-1" ]]; then
    xrandr --output DP-1 --mode 3840x2160
fi

if [[ $# == 0 ]]; then
    echo "Available screens:\n"
    while read -r line; do
        echo $line
    done <<< "$(xrandr | grep connected | cut -d' ' -f1,2)"

    echo "\nExamples:"
    echo "output SCREEN"
    echo "output SCREEN off"
elif [[ $# == 1 ]]; then
    xrandr --output $1 --auto
elif [[ $# == 2 ]]; then
    if [[ $2 == off ]]; then
        xrandr --output $1 --off
    else
        xrandr --output $1 --mode $2
    fi
fi

